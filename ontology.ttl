                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :RiskClassification
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :manufacturedBy ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :Manufacturer
                               ] ;
               rdfs:comment "A medical device or in vitro diagnostic device included in the catalogue."@en ;
               rdfs:label "Medical device"@en ;
               rdfs:seeAlso <https://schema.org/MedicalDevice> .


