          :hasActionDate "2024-02-01"^^xsd:date ;
          :hasAffectedDeviceCount 850 ;
          :hasEudamedFscaRef "EU-FSCA-2024-000001" ;
          :hasFscaDescription "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0." ;
          :hasFscaId "FSCA-001" ;
          :hasScopeDescription "All HeartMate 3 LVAD units implanted since 2020" ;
          rdfs:comment "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0."@en ;
          rdfs:label "FSCA-001"@en .


