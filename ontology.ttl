@prefix : <http://www.example.org/meddevice#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.example.org/meddevice#> .

<http://www.example.org/meddevice> rdf:type owl:Ontology ;
                                    <http://purl.org/dc/terms/creator> "Lluc Manuel Ferré Escobet"@en ;
                                    <http://purl.org/dc/terms/description> "Ontology for representing European high-risk medical devices, manufacturers, risks, incidents and field safety corrective actions."@en ;
                                    <http://purl.org/dc/terms/source> <https://ec.europa.eu/tools/eudamed/#/screen/home> ;
                                    <http://purl.org/dc/terms/title> "European High-Risk Medical Device Ontology"@en ;
                                    owl:versionInfo "1.0"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
<http://purl.org/dc/terms/source> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument1
<http://www.w3.org/2003/11/swrl#argument1> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#argument2
<http://www.w3.org/2003/11/swrl#argument2> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#body
<http://www.w3.org/2003/11/swrl#body> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#classPredicate
<http://www.w3.org/2003/11/swrl#classPredicate> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#head
<http://www.w3.org/2003/11/swrl#head> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/11/swrl#propertyPredicate
<http://www.w3.org/2003/11/swrl#propertyPredicate> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
<http://www.w3.org/2004/02/skos/core#prefLabel> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/meddevice#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :DeviceType ;
                   rdfs:comment "Relates a risk to the type of device affected by it."@en ;
                   rdfs:label "affects device type"@en .


###  http://www.example.org/meddevice#affectsRegion
:affectsRegion rdf:type owl:ObjectProperty ;
               rdfs:domain :FieldSafetyCorrectiveAction ;
               rdfs:range :AffectedRegion ;
               rdfs:comment "Relates a corrective action to an affected region."@en ;
               rdfs:label "affects region"@en .


###  http://www.example.org/meddevice#associatedWithRisk
:associatedWithRisk rdf:type owl:ObjectProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range :Risk ;
                    rdfs:comment "Relates an incident to an associated risk."@en ;
                    rdfs:label "associated with risk"@en .


###  http://www.example.org/meddevice#authorizedBy
:authorizedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :CompetentAuthority ;
              rdfs:comment "Relates a manufacturer to its competent authority."@en ;
              rdfs:label "authorized by"@en .


###  http://www.example.org/meddevice#correctsIncident
:correctsIncident rdf:type owl:ObjectProperty ;
                  rdfs:domain :FieldSafetyCorrectiveAction ;
                  rdfs:range :Incident ;
                  rdfs:comment "Relates a field safety corrective action to the incident it addresses."@en ;
                  rdfs:label "corrects incident"@en .


###  http://www.example.org/meddevice#hasCorrectiveActionStatus
:hasCorrectiveActionStatus rdf:type owl:ObjectProperty ;
                           rdfs:domain :FieldSafetyCorrectiveAction ;
                           rdfs:range :CorrectiveActionStatus ;
                           rdfs:comment "Relates a corrective action to its current status."@en ;
                           rdfs:label "has corrective action status"@en .


###  http://www.example.org/meddevice#hasCorrectiveActionType
:hasCorrectiveActionType rdf:type owl:ObjectProperty ;
                         rdfs:domain :FieldSafetyCorrectiveAction ;
                         rdfs:range :CorrectiveActionType ;
                         rdfs:comment "Relates a corrective action to its type."@en ;
                         rdfs:label "has corrective action type"@en .


###  http://www.example.org/meddevice#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range :DeviceType ;
               rdfs:comment "Relates a device to its controlled device type."@en ;
               rdfs:label "has device type"@en .


###  http://www.example.org/meddevice#hasIncidentType
:hasIncidentType rdf:type owl:ObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :IncidentType ;
                 rdfs:comment "Relates an incident to its controlled incident type."@en ;
                 rdfs:label "has incident type"@en .


###  http://www.example.org/meddevice#hasPatientSex
:hasPatientSex rdf:type owl:ObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :PatientSex ;
               rdfs:comment "Relates an incident to a controlled patient sex value."@en ;
               rdfs:label "has patient sex"@en .


###  http://www.example.org/meddevice#hasProbabilityLevel
:hasProbabilityLevel rdf:type owl:ObjectProperty ;
                     rdfs:domain :Risk ;
                     rdfs:range :ProbabilityLevel ;
                     rdfs:comment "Relates a risk to its probability level."@en ;
                     rdfs:label "has probability level"@en .


###  http://www.example.org/meddevice#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :RiskCategory ;
                 rdfs:comment "Relates a risk to a controlled risk category."@en ;
                 rdfs:label "has risk category"@en .


###  http://www.example.org/meddevice#hasRiskClassification
:hasRiskClassification rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :MedicalDevice ;
                       rdfs:range :RiskClassification ;
                       rdfs:comment "Relates a device to its regulatory risk classification."@en ;
                       rdfs:label "has risk classification"@en .


###  http://www.example.org/meddevice#hasRiskType
:hasRiskType rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskType ;
             rdfs:comment "Relates a risk to a controlled risk type."@en ;
             rdfs:label "has risk type"@en .


###  http://www.example.org/meddevice#hasSeverityLevel
:hasSeverityLevel rdf:type owl:ObjectProperty ;
                  rdfs:domain :Risk ;
                  rdfs:range :SeverityLevel ;
                  rdfs:comment "Relates a risk to its severity level."@en ;
                  rdfs:label "has severity level"@en .


###  http://www.example.org/meddevice#includesCountry
:includesCountry rdf:type owl:ObjectProperty ;
                 rdfs:domain :AffectedRegion ;
                 rdfs:range :Country ;
                 rdfs:comment "Relates an affected region to one of its countries."@en ;
                 rdfs:label "includes country"@en .


###  http://www.example.org/meddevice#involvesDevice
:involvesDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :MedicalDevice ;
                rdfs:comment "Relates an incident to the device involved in it."@en ;
                rdfs:label "involves device"@en .


###  http://www.example.org/meddevice#locatedInCountry
:locatedInCountry rdf:type owl:ObjectProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range :Country ;
                  rdfs:comment "Relates a manufacturer to its country."@en ;
                  rdfs:label "located in country"@en .


###  http://www.example.org/meddevice#manufacturedBy
:manufacturedBy rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :MedicalDevice ;
                rdfs:range :Manufacturer ;
                rdfs:comment "Relates a medical device to its manufacturer."@en ;
                rdfs:label "manufactured by"@en .


###  http://www.example.org/meddevice#regulatedBy
:regulatedBy rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :MedicalDevice ;
             rdfs:range :RegulatoryFramework ;
             rdfs:comment "Relates a device to its applicable regulatory framework."@en ;
             rdfs:label "regulated by"@en .


###  http://www.example.org/meddevice#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Relates an incident to the reporting entity."@en ;
            rdfs:label "reported by"@en .


###  http://www.example.org/meddevice#reportedInCountry
:reportedInCountry rdf:type owl:ObjectProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range :Country ;
                   rdfs:comment "Relates an incident to the country in which it was reported."@en ;
                   rdfs:label "reported in country"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/meddevice#hasActionDate
:hasActionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :FieldSafetyCorrectiveAction ;
               rdfs:range xsd:date ;
               rdfs:comment "Start date of the corrective action."@en ;
               rdfs:label "has action date"@en .


###  http://www.example.org/meddevice#hasAffectedDeviceCount
:hasAffectedDeviceCount rdf:type owl:DatatypeProperty ;
                        rdfs:domain :FieldSafetyCorrectiveAction ;
                        rdfs:range xsd:integer ;
                        rdfs:comment "Number of devices affected by the corrective action."@en ;
                        rdfs:label "has affected device count"@en .


###  http://www.example.org/meddevice#hasAuthorizationNumber
:hasAuthorizationNumber rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Manufacturer ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Authorization number of the manufacturer."@en ;
                        rdfs:label "has authorization number"@en .


###  http://www.example.org/meddevice#hasClosureDate
:hasClosureDate rdf:type owl:DatatypeProperty ;
                rdfs:domain :FieldSafetyCorrectiveAction ;
                rdfs:range xsd:date ;
                rdfs:comment "Closure date of the corrective action."@en ;
                rdfs:label "has closure date"@en .


###  http://www.example.org/meddevice#hasContactEmail
:hasContactEmail rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Manufacturer ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Contact email of the manufacturer."@en ;
                 rdfs:label "has contact email"@en .


###  http://www.example.org/meddevice#hasCorrectiveActionTaken
:hasCorrectiveActionTaken rdf:type owl:DatatypeProperty ;
                          rdfs:domain :Incident ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "Indicates whether a corrective action was taken."@en ;
                          rdfs:label "has corrective action taken"@en .


###  http://www.example.org/meddevice#hasDetectionDate
:hasDetectionDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range xsd:date ;
                  rdfs:comment "Date when the incident was detected."@en ;
                  rdfs:label "has detection date"@en .


###  http://www.example.org/meddevice#hasDeviceId
:hasDeviceId rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :MedicalDevice ;
             rdfs:range xsd:string ;
             rdfs:comment "Device identifier."@en ;
             rdfs:label "has device id"@en .


###  http://www.example.org/meddevice#hasDeviceName
:hasDeviceName rdf:type owl:DatatypeProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:string ;
               rdfs:comment "Commercial name of the device."@en ;
               rdfs:label "has device name"@en .


###  http://www.example.org/meddevice#hasEudamedFscaRef
:hasEudamedFscaRef rdf:type owl:DatatypeProperty ;
                   rdfs:domain :FieldSafetyCorrectiveAction ;
                   rdfs:range xsd:string ;
                   rdfs:comment "EUDAMED reference for the corrective action."@en ;
                   rdfs:label "has EUDAMED FSCA reference"@en .


###  http://www.example.org/meddevice#hasEudamedIncidentRef
:hasEudamedIncidentRef rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:string ;
                       rdfs:comment "EUDAMED reference for the incident."@en ;
                       rdfs:label "has EUDAMED incident reference"@en .


###  http://www.example.org/meddevice#hasEudamedSrn
:hasEudamedSrn rdf:type owl:DatatypeProperty ;
               rdfs:domain :Manufacturer ;
               rdfs:range xsd:string ;
               rdfs:comment "Single Registration Number in EUDAMED."@en ;
               rdfs:label "has EUDAMED SRN"@en .


###  http://www.example.org/meddevice#hasEventDate
:hasEventDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :Incident ;
              rdfs:range xsd:date ;
              rdfs:comment "Date when the event occurred."@en ;
              rdfs:label "has event date"@en .


###  http://www.example.org/meddevice#hasFscaDescription
:hasFscaDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :FieldSafetyCorrectiveAction ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Description of the field safety corrective action."@en ;
                    rdfs:label "has FSCA description"@en .


###  http://www.example.org/meddevice#hasFscaId
:hasFscaId rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :FieldSafetyCorrectiveAction ;
           rdfs:range xsd:string ;
           rdfs:comment "Field safety corrective action identifier."@en ;
           rdfs:label "has FSCA id"@en .


###  http://www.example.org/meddevice#hasImdrfCode
:hasImdrfCode rdf:type owl:DatatypeProperty ;
              rdfs:domain :Risk ;
              rdfs:range xsd:string ;
              rdfs:comment "IMDRF risk code."@en ;
              rdfs:label "has IMDRF code"@en .


###  http://www.example.org/meddevice#hasIncidentDescription
:hasIncidentDescription rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Incident ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Description of the incident."@en ;
                        rdfs:label "has incident description"@en .


###  http://www.example.org/meddevice#hasIncidentId
:hasIncidentId rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "Incident identifier."@en ;
               rdfs:label "has incident id"@en .


###  http://www.example.org/meddevice#hasIntendedPurpose
:hasIntendedPurpose rdf:type owl:DatatypeProperty ;
                    rdfs:domain :MedicalDevice ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Intended purpose of the device."@en ;
                    rdfs:label "has intended purpose"@en .


###  http://www.example.org/meddevice#hasManufacturerId
:hasManufacturerId rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :Manufacturer ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Manufacturer identifier."@en ;
                   rdfs:label "has manufacturer id"@en .


###  http://www.example.org/meddevice#hasManufacturerName
:hasManufacturerName rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Legal name of the manufacturer."@en ;
                     rdfs:label "has manufacturer name"@en .


###  http://www.example.org/meddevice#hasOutcome
:hasOutcome rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Clinical or technical outcome of the incident."@en ;
            rdfs:label "has outcome"@en .


###  http://www.example.org/meddevice#hasPatientAge
:hasPatientAge rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:integer ;
               rdfs:comment "Age of the patient involved in the incident."@en ;
               rdfs:label "has patient age"@en .


###  http://www.example.org/meddevice#hasReportDate
:hasReportDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "Date when the incident was reported."@en ;
               rdfs:label "has report date"@en .


###  http://www.example.org/meddevice#hasRiskDescription
:hasRiskDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Textual description of the risk."@en ;
                    rdfs:label "has risk description"@en .


###  http://www.example.org/meddevice#hasRiskId
:hasRiskId rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "Risk identifier."@en ;
           rdfs:label "has risk id"@en .


###  http://www.example.org/meddevice#hasRiskName
:hasRiskName rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Name of the risk."@en ;
             rdfs:label "has risk name"@en .


###  http://www.example.org/meddevice#hasScopeDescription
:hasScopeDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain :FieldSafetyCorrectiveAction ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Textual description of the scope of the corrective action."@en ;
                     rdfs:label "has scope description"@en .


###  http://www.example.org/meddevice#hasUdiDi
:hasUdiDi rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:string ;
          rdfs:comment "Unique Device Identifier - Device Identifier."@en ;
          rdfs:label "has UDI-DI"@en .


###  http://www.example.org/meddevice#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device is active."@en ;
          rdfs:label "is active"@en .


###  http://www.example.org/meddevice#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is implantable."@en ;
               rdfs:label "is implantable"@en .


###  http://www.example.org/meddevice#isIvd
:isIvd rdf:type owl:DatatypeProperty ;
       rdfs:domain :MedicalDevice ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Indicates whether the device is an in vitro diagnostic device."@en ;
       rdfs:label "is IVD"@en .


###  http://www.example.org/meddevice#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :MedicalDevice ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device is reusable."@en ;
            rdfs:label "is reusable"@en .


#################################################################
#    Classes
#################################################################

###  http://www.example.org/meddevice#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDevice ;
              rdfs:comment "A device that depends on a source of energy other than that generated by the human body."@en ;
              rdfs:label "Active Device"@en .


###  http://www.example.org/meddevice#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :MedicalDevice ;
               rdfs:comment "An active implantable medical device."@en ;
               rdfs:label "Active Implant"@en .


###  http://www.example.org/meddevice#AffectedRegion
:AffectedRegion rdf:type owl:Class ;
                rdfs:subClassOf :MedicalDeviceOntologyEntity ;
                rdfs:comment "Region or countries affected by a corrective action."@en ;
                rdfs:label "Affected region"@en .


###  http://www.example.org/meddevice#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:subClassOf :MedicalDeviceOntologyEntity ;
                    rdfs:comment "Regulatory authority responsible for authorization or oversight."@en ;
                    rdfs:label "Competent authority"@en .


###  http://www.example.org/meddevice#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk subtype corresponding to contamination risk."@en ;
                   rdfs:label "Contamination Risk"@en .


###  http://www.example.org/meddevice#CorrectiveActionRequiredIncident
:CorrectiveActionRequiredIncident rdf:type owl:Class ;
                                  rdfs:subClassOf :Incident ;
                                  rdfs:comment "An incident for which a corrective action has been taken."@en ;
                                  rdfs:label "Corrective action required incident"@en .


###  http://www.example.org/meddevice#CorrectiveActionStatus
:CorrectiveActionStatus rdf:type owl:Class ;
                        rdfs:subClassOf :MedicalDeviceOntologyEntity ;
                        rdfs:comment "Controlled status of a corrective action."@en ;
                        rdfs:label "Corrective action status"@en .


###  http://www.example.org/meddevice#CorrectiveActionType
:CorrectiveActionType rdf:type owl:Class ;
                      rdfs:subClassOf :MedicalDeviceOntologyEntity ;
                      rdfs:comment "Controlled type of corrective action."@en ;
                      rdfs:label "Corrective action type"@en .


###  http://www.example.org/meddevice#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf :MedicalDeviceOntologyEntity ;
         rdfs:comment "Country associated with manufacturers, incidents or corrective actions."@en ;
         rdfs:label "Country"@en .


###  http://www.example.org/meddevice#CriticalRisk
:CriticalRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "A risk inferred as critical by the SWRL rules."@en ;
              rdfs:label "Critical risk"@en .


###  http://www.example.org/meddevice#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk subtype corresponding to cybersecurity risk."@en ;
                   rdfs:label "Cybersecurity Risk"@en .


###  http://www.example.org/meddevice#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:subClassOf :MedicalDeviceOntologyEntity ;
            rdfs:comment "Controlled category describing a type of medical device."@en ;
            rdfs:label "Device type"@en .


###  http://www.example.org/meddevice#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk subtype corresponding to diagnostic risk."@en ;
                rdfs:label "Diagnostic Risk"@en .


###  http://www.example.org/meddevice#FieldSafetyCorrectiveAction
:FieldSafetyCorrectiveAction rdf:type owl:Class ;
                             rdfs:subClassOf :MedicalDeviceOntologyEntity ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :correctsIncident ;
                                               owl:someValuesFrom :Incident
                                             ] ;
                             rdfs:comment "A field safety corrective action related to a reported incident."@en ;
                             rdfs:label "Field safety corrective action"@en .


###  http://www.example.org/meddevice#HighRiskDevice
:HighRiskDevice rdf:type owl:Class ;
                rdfs:subClassOf :MedicalDevice ;
                rdfs:comment "A device inferred as high-risk by the SWRL rules."@en ;
                rdfs:label "High-risk device"@en .


###  http://www.example.org/meddevice#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "A medical device that is both implantable and active."@en ;
                         rdfs:label "Implantable Active Device"@en .


###  http://www.example.org/meddevice#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :MedicalDevice ;
                   rdfs:comment "A device intended to be totally or partially introduced into the human body."@en ;
                   rdfs:label "Implantable Device"@en .


###  http://www.example.org/meddevice#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "A device used for in vitro diagnostic purposes."@en ;
                         rdfs:label "In Vitro Diagnostic Device"@en .


###  http://www.example.org/meddevice#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :MedicalDeviceOntologyEntity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :involvesDevice ;
                            owl:someValuesFrom :MedicalDevice
                          ] ;
          rdfs:comment "An incident reported for a medical device."@en ;
          rdfs:label "Incident"@en .


###  http://www.example.org/meddevice#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDeviceOntologyEntity ;
