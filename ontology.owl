    </owl:Class>
    


    <!-- http://www.example.org/meddevice#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device used for in vitro diagnostic purposes.</rdfs:comment>
