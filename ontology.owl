    <owl:Class rdf:about="http://www.example.org/meddevice#DeviceType">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDeviceOntologyEntity"/>
        <rdfs:comment xml:lang="en">Controlled category describing a type of medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Risk subtype corresponding to diagnostic risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#FieldSafetyCorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/meddevice#FieldSafetyCorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDeviceOntologyEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#correctsIncident"/>
                <owl:someValuesFrom rdf:resource="http://www.example.org/meddevice#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A field safety corrective action related to a reported incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Field safety corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#HighRiskDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#HighRiskDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device inferred as high-risk by the SWRL rules.</rdfs:comment>
        <rdfs:label xml:lang="en">High-risk device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#ImplantableActiveDevice">
