<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/meddevice#"
     xml:base="http://www.example.org/meddevice"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:meddevice="http://www.example.org/meddevice#">
    <owl:Ontology rdf:about="http://www.example.org/meddevice">
        <terms:creator xml:lang="en">Lluc Manuel Ferré Escobet</terms:creator>
        <terms:description xml:lang="en">Ontology for representing European high-risk medical devices, manufacturers, risks, incidents and field safety corrective actions.</terms:description>
        <terms:source rdf:resource="https://ec.europa.eu/tools/eudamed/#/screen/home"/>
        <terms:title xml:lang="en">European High-Risk Medical Device Ontology</terms:title>
        <owl:versionInfo xml:lang="en">1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/source -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/source"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument1 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument1"/>
    


    <!-- http://www.w3.org/2003/11/swrl#argument2 -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#argument2"/>
    


    <!-- http://www.w3.org/2003/11/swrl#body -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#body"/>
    


    <!-- http://www.w3.org/2003/11/swrl#classPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#classPredicate"/>
    


    <!-- http://www.w3.org/2003/11/swrl#head -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#head"/>
    


    <!-- http://www.w3.org/2003/11/swrl#propertyPredicate -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2003/11/swrl#propertyPredicate"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/meddevice#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#affectsDeviceType">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#DeviceType"/>
        <rdfs:comment xml:lang="en">Relates a risk to the type of device affected by it.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#affectsRegion -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#affectsRegion">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#AffectedRegion"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to an affected region.</rdfs:comment>
        <rdfs:label xml:lang="en">affects region</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#associatedWithRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#associatedWithRisk">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to an associated risk.</rdfs:comment>
        <rdfs:label xml:lang="en">associated with risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#authorizedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#authorizedBy">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to its competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">authorized by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#correctsIncident -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#correctsIncident">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:comment xml:lang="en">Relates a field safety corrective action to the incident it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">corrects incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasCorrectiveActionStatus -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasCorrectiveActionStatus">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#CorrectiveActionStatus"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to its current status.</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasCorrectiveActionType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasCorrectiveActionType">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#CorrectiveActionType"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to its type.</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#DeviceType"/>
        <rdfs:comment xml:lang="en">Relates a device to its controlled device type.</rdfs:comment>
        <rdfs:label xml:lang="en">has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasIncidentType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasIncidentType">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#IncidentType"/>
        <rdfs:comment xml:lang="en">Relates an incident to its controlled incident type.</rdfs:comment>
        <rdfs:label xml:lang="en">has incident type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasPatientSex -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasPatientSex">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#PatientSex"/>
        <rdfs:comment xml:lang="en">Relates an incident to a controlled patient sex value.</rdfs:comment>
        <rdfs:label xml:lang="en">has patient sex</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasProbabilityLevel -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasProbabilityLevel">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#ProbabilityLevel"/>
        <rdfs:comment xml:lang="en">Relates a risk to its probability level.</rdfs:comment>
        <rdfs:label xml:lang="en">has probability level</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasRiskCategory -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasRiskCategory">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#RiskCategory"/>
        <rdfs:comment xml:lang="en">Relates a risk to a controlled risk category.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasRiskClassification -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasRiskClassification">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#RiskClassification"/>
        <rdfs:comment xml:lang="en">Relates a device to its regulatory risk classification.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk classification</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasRiskType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasRiskType">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#RiskType"/>
        <rdfs:comment xml:lang="en">Relates a risk to a controlled risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasSeverityLevel -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasSeverityLevel">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#SeverityLevel"/>
        <rdfs:comment xml:lang="en">Relates a risk to its severity level.</rdfs:comment>
        <rdfs:label xml:lang="en">has severity level</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#includesCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#includesCountry">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#AffectedRegion"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Country"/>
        <rdfs:comment xml:lang="en">Relates an affected region to one of its countries.</rdfs:comment>
        <rdfs:label xml:lang="en">includes country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#involvesDevice">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Relates an incident to the device involved in it.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#locatedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#locatedInCountry">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Country"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to its country.</rdfs:comment>
        <rdfs:label xml:lang="en">located in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#manufacturedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#manufacturedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#regulatedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#regulatedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Relates a device to its applicable regulatory framework.</rdfs:comment>
        <rdfs:label xml:lang="en">regulated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#reportedBy">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates an incident to the reporting entity.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#reportedInCountry">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Country"/>
        <rdfs:comment xml:lang="en">Relates an incident to the country in which it was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/meddevice#hasActionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasActionDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Start date of the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasAffectedDeviceCount -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasAffectedDeviceCount">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of devices affected by the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has affected device count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasAuthorizationNumber">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Authorization number of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasClosureDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasClosureDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Closure date of the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasContactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasContactEmail">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Contact email of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasCorrectiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasCorrectiveActionTaken">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a corrective action was taken.</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasDetectionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasDetectionDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">has detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasDeviceId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasDeviceId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Device identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">has device id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasDeviceName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasDeviceName">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Commercial name of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">has device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasEudamedFscaRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasEudamedFscaRef">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">EUDAMED reference for the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasEudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasEudamedIncidentRef">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">EUDAMED reference for the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasEudamedSrn -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasEudamedSrn">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Single Registration Number in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasEventDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasEventDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the event occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">has event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasFscaDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasFscaDescription">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasFscaId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasFscaId">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Field safety corrective action identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA id</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasImdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasImdrfCode">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">IMDRF risk code.</rdfs:comment>
        <rdfs:label xml:lang="en">has IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#hasIncidentDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#hasIncidentDescription">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description of the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">has incident description</rdfs:label>
