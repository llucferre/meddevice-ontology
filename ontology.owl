        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Risk subtype corresponding to contamination risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


