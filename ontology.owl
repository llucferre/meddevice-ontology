    <!-- http://www.example.org/meddevice#Incident -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Incident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDeviceOntologyEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#involvesDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An incident reported for a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#IncidentType -->


    <owl:Class rdf:about="http://www.example.org/meddevice#IncidentType">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDeviceOntologyEntity"/>
        <rdfs:comment xml:lang="en">Controlled type used to classify incidents.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#InfectionRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Risk subtype corresponding to infection risk.</rdfs:comment>
