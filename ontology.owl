    </owl:Class>
    


    <!-- http://www.example.org/meddevice#CriticalRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#CriticalRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">A risk inferred as critical by the SWRL rules.</rdfs:comment>
        <rdfs:label xml:lang="en">Critical risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
