    <owl:Class rdf:about="http://www.example.org/meddevice#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A legal manufacturer of medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#MaterialRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Risk subtype corresponding to material risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#MdrRiskClass -->


    <owl:Class rdf:about="http://www.example.org/meddevice#MdrRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#RiskClassification"/>
        <rdfs:comment xml:lang="en">Risk class defined under the Medical Device Regulation.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR risk class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#MedicalDevice -->


    <owl:Class rdf:about="http://www.example.org/meddevice#MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#MedicalDeviceOntologyEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#hasRiskClassification"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/meddevice#RiskClassification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#manufacturedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device or in vitro diagnostic device included in the catalogue.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical device</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://schema.org/MedicalDevice"/>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#MedicalDeviceOntologyEntity -->


    <owl:Class rdf:about="http://www.example.org/meddevice#MedicalDeviceOntologyEntity">
        <rdfs:comment xml:lang="en">Root class for all entities in the medical device ontology.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical device ontology entity</rdfs:label>
    </owl:Class>
    


